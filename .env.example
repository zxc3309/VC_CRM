# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# AI Provider Configuration
# Supported: openai, google, anthropic
AI_PROVIDER=openai

# OpenAI Configuration (required if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration (required if AI_PROVIDER=google)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Anthropic Claude Configuration (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apify Configuration (for LinkedIn scraping)
APIFY_API_TOKEN=your_apify_api_token_here

# Email for DocSend access
DOCSEND_EMAIL=your_email@example.com

# Bot Function Folder
WORKING_DIRECTORY=/path/to/your/working/directory

# Tesseract OCR executable path
# Windows: C:\\Program Files\\Tesseract-OCR\\tesseract.exe
# macOS: /opt/homebrew/bin/tesseract
# Linux: /usr/bin/tesseract
TESSERACT_CMD=/path/to/tesseract

#Google Drive Folder
GOOGLE_DRIVE_FOLDER_ID=your_google_log_folder_id_here

#Google Sheet_Prompt Manager
PROMPT_MANAGER=your_google_prompt_sheet_id_here

#Google Service Account Container
SERVICE_ACCOUNT_BASE64=place_your_service_account_64base_format_here

# Logging Configuration (Optional)
# Set to DEBUG for detailed logs, INFO for normal operation, WARNING for minimal logs
LOG_LEVEL=INFO